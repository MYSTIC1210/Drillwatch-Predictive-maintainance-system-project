# ── Stage 1: Build ──────────────────────────────────────────
FROM node:20-alpine AS builder

LABEL stage="builder"
WORKDIR /app

# Build-time arg for API URL (Vite bakes VITE_* at compile time)
ARG VITE_API_BASE_URL=http://localhost:8000
ARG VITE_POLL_INTERVAL_MS=2000
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ENV VITE_POLL_INTERVAL_MS=${VITE_POLL_INTERVAL_MS}

COPY package.json ./
RUN npm install --silent

COPY . .
RUN npm run build

# ── Stage 2: Serve with Nginx ────────────────────────────────
FROM nginx:1.27-alpine

LABEL maintainer="DrillWatch Engineering"
LABEL description="React Dashboard — DrillWatch PdM System"

RUN rm /etc/nginx/conf.d/default.conf
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
