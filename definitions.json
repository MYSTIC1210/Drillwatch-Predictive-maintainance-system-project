{
  "rabbit_version": "3.12.0",
  "vhosts": [{ "name": "/" }],
  "exchanges": [
    {
      "name": "drill.exchange",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "drill.telemetry",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-message-ttl": 60000,
        "x-max-length": 10000
      }
    }
  ],
  "bindings": [
    {
      "source": "drill.exchange",
      "vhost": "/",
      "destination": "drill.telemetry",
      "destination_type": "queue",
      "routing_key": "telemetry.#",
      "arguments": {}
    }
  ]
}
